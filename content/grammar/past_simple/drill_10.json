        {
            "id": "ps-dv-0091",
            "type": "drill_verb",
            "header": "επιστρέφω (to return / come back)",
            "conjugations": [
                {
                    "form": "εγώ",
                    "options": {"a": "επέστρεψα", "b": "επέστρεψες", "c": "επέστρεψε", "d": "επιστρέψαμε"},
                    "answer": "a",
                    "explanation": "επιστρέφω ends in -φ. The -φ + -σ → -ψ. The augment έ- is inserted after the prefix επι-: επι-έ-στρεψα → επέστρεψα."
                },
                {
                    "form": "εσύ",
                    "options": {"a": "επέστρεψα", "b": "επέστρεψες", "c": "επιστρέψαμε", "d": "επιστρέψατε"},
                    "answer": "b",
                    "explanation": "Same stem. 2sg ending -ες: επέστρεψες."
                },
                {
                    "form": "αυτός / αυτή / αυτό",
                    "options": {"a": "επέστρεψες", "b": "επιστρέψαμε", "c": "επέστρεψε", "d": "επέστρεψαν"},
                    "answer": "c",
                    "explanation": "Same stem. 3sg ending -ε: επέστρεψε."
                },
                {
                    "form": "εμείς",
                    "options": {"a": "επέστρεψαν", "b": "επέστρεψες", "c": "επέστρεψε", "d": "επιστρέψαμε"},
                    "answer": "d",
                    "explanation": "In 1pl, the augment drops. Ending -αμε: επιστρέψαμε."
                },
                {
                    "form": "εσείς",
                    "options": {"a": "επιστρέψατε", "b": "επέστρεψε", "c": "επέστρεψαν", "d": "επέστρεψα"},
                    "answer": "a",
                    "explanation": "In 2pl, the augment drops. Ending -ατε: επιστρέψατε."
                },
                {
                    "form": "αυτοί / αυτές / αυτά",
                    "options": {"a": "επιστρέψαμε", "b": "επέστρεψαν", "c": "επέστρεψες", "d": "επιστρέψατε"},
                    "answer": "b",
                    "explanation": "3pl ending -αν: επέστρεψαν."
                }
            ]
        },
