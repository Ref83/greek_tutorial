        {
            "id": "ps-dv-0031",
            "type": "drill_verb",
            "header": "μιλώ (to speak / talk)",
            "conjugations": [
                {
                    "form": "εγώ",
                    "options": {"a": "μίλησα", "b": "μίλησες", "c": "μίλησε", "d": "μιλήσαμε"},
                    "answer": "a",
                    "explanation": "μιλώ is a Group B verb (ending in -ώ). In the past, add -ησ- before the endings. 1sg: μίλησα."
                },
                {
                    "form": "εσύ",
                    "options": {"a": "μίλησα", "b": "μίλησες", "c": "μιλήσαμε", "d": "μιλήσατε"},
                    "answer": "b",
                    "explanation": "Same -ησ- stem. 2sg ending -ες: μίλησες."
                },
                {
                    "form": "αυτός / αυτή / αυτό",
                    "options": {"a": "μίλησες", "b": "μιλήσαμε", "c": "μίλησε", "d": "μίλησαν"},
                    "answer": "c",
                    "explanation": "Same -ησ- stem. 3sg ending -ε: μίλησε."
                },
                {
                    "form": "εμείς",
                    "options": {"a": "μίλησαν", "b": "μίλησες", "c": "μίλησε", "d": "μιλήσαμε"},
                    "answer": "d",
                    "explanation": "1pl ending -αμε: μιλήσαμε. The stress falls on -ή-."
                },
                {
                    "form": "εσείς",
                    "options": {"a": "μιλήσατε", "b": "μίλησε", "c": "μίλησαν", "d": "μίλησα"},
                    "answer": "a",
                    "explanation": "2pl ending -ατε: μιλήσατε."
                },
                {
                    "form": "αυτοί / αυτές / αυτά",
                    "options": {"a": "μιλήσαμε", "b": "μίλησαν", "c": "μίλησες", "d": "μιλήσατε"},
                    "answer": "b",
                    "explanation": "3pl ending -αν: μίλησαν."
