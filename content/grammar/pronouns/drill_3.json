{
    "exercises": [
        {
            "id": "pr-0051-4000-8000-000000000051",
            "type": "drill",
            "header": "What is 'με' used for?",
            "options": {
                "a": "Possessive (my)",
                "b": "Direct object (me)",
                "c": "Indirect object (to me)",
                "d": "Subject (I)"
            },
            "answer": "b",
            "explanation": "Με is the direct object (accusative) personal pronoun meaning 'me'. Example: Με βλέπεις. (You see me.) Contrast with μου which is possessive (my) or indirect object (to me)."
        },
        {
            "id": "pr-0052-4000-8000-000000000052",
            "type": "drill",
            "header": "What is 'μου' used for?",
            "options": {
                "a": "Direct object (me)",
                "b": "Subject (I)",
                "c": "Possessive (my) and indirect object (to me)",
                "d": "Never used in modern Greek"
            },
            "answer": "c",
            "explanation": "Μου serves two purposes: possessive 'my' (το σπίτι μου — my house) and indirect object 'to me' (Μου γράφει — She writes to me). Contrast with με which is the direct object."
        },
        {
            "id": "pr-0053-4000-8000-000000000053",
            "type": "drill",
            "header": "Αυτός ___ βλέπει. (He sees me.)",
            "options": {
                "a": "μου",
                "b": "με",
                "c": "μας",
                "d": "εμένα"
            },
            "answer": "b",
            "explanation": "Με is the direct object pronoun for 'me'. Αυτός με βλέπει. The pronoun goes before the verb."
        },
        {
            "id": "pr-0054-4000-8000-000000000054",
            "type": "drill",
            "header": "Το σπίτι ___. (My house.)",
            "options": {
                "a": "με",
                "b": "εγώ",
                "c": "μου",
                "d": "εμένα"
            },
            "answer": "c",
            "explanation": "Μου is the possessive pronoun for 'my'. It follows the noun: Το σπίτι μου."
        },
        {
            "id": "pr-0055-4000-8000-000000000055",
            "type": "drill",
            "header": "Αυτός ___ βλέπει. (He sees her.)",
            "options": {
                "a": "της",
                "b": "τη",
                "c": "την",
                "d": "αυτή"
            },
            "answer": "c",
            "explanation": "Την is the direct object pronoun for 'her'. Αυτός την βλέπει. (Note: τη is also acceptable in spoken Greek, but την is the standard form.)"
        },
        {
            "id": "pr-0056-4000-8000-000000000056",
            "type": "drill",
            "header": "Το αυτοκίνητο ___. (Her car.)",
