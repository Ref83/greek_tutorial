        {
            "id": "pr-0064-4000-8000-000000000064",
            "type": "drill",
            "header": "Which is the correct word order for 'I see him'?",
            "options": {
                "a": "Βλέπω τον.",
                "b": "Τον βλέπω.",
                "c": "Βλέπω αυτόν.",
                "d": "Αυτόν βλέπω."
            },
            "answer": "b",
            "explanation": "Τον βλέπω. — The weak object pronoun goes BEFORE the verb in statements. The form 'Βλέπω τον' is incorrect; 'Βλέπω αυτόν' uses the strong pronoun which is grammatically possible but less common."
        },
