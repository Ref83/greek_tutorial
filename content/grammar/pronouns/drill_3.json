        {
            "id": "pr-0071-4000-8000-000000000071",
            "type": "drill",
            "header": "Which of these is NOT a possessive pronoun?",
            "options": {
                "a": "μου",
                "b": "σου",
                "c": "με",
                "d": "τους"
            },
            "answer": "c",
            "explanation": "Με is a personal accusative (direct object) pronoun meaning 'me', not a possessive. The possessives are: μου, σου, του, της, μας, σας, τους."
        },
        {
            "id": "pr-0072-4000-8000-000000000072",
            "type": "drill",
            "header": "Which of these is NOT a personal accusative pronoun?",
            "options": {
                "a": "με",
                "b": "σε",
                "c": "τον",
                "d": "μου"
            },
            "answer": "d",
            "explanation": "Μου is a possessive/indirect pronoun (meaning 'my' or 'to me'), not a direct object accusative. The accusative personal pronouns are: με, σε, τον, την, το, μας, σας, τους, τις, τα."
        },
