            "story": {
                "sentences": [
                    {
                        "sentence": "Σήμερα θέλω να φτιάξω ένα κέικ.",
                        "translation": "Today I want to make a cake."
                    },
                    {
                        "sentence": "Βγάζω το αλεύρι, τη ζάχαρη και το αλάτι από το ντουλάπι.",
                        "translation": "I take out the flour, sugar, and salt from the cupboard."
                    },
                    {
                        "sentence": "Χρειάζομαι επίσης γάλα, αυγά και βούτυρο.",
                        "translation": "I also need milk, eggs, and butter."
                    },
                    {
                        "sentence": "Ανοίγω το ψυγείο και βγάζω τρία αυγά.",
                        "translation": "I open the fridge and take out three eggs."
                    },
                    {
                        "sentence": "Λιώνω το βούτυρο σε χαμηλή φωτιά.",
                        "translation": "I melt the butter on low heat."
                    },
                    {
                        "sentence": "Ανακατεύω το αλεύρι με τη ζάχαρη και τη μαγειρική σόδα.",
                        "translation": "I mix the flour with the sugar and baking soda."
                    },
                    {
                        "sentence": "Προσθέτω βανίλια και λίγη κανέλα για άρωμα.",
                        "translation": "I add vanilla and a little cinnamon for aroma."
                    },
                    {
                        "sentence": "Χτυπάω τα αυγά με το γάλα και το λιωμένο βούτυρο.",
                        "translation": "I beat the eggs with the milk and the melted butter."
                    },
                    {
                        "sentence": "Ενώνω τα υγρά με τα στερεά υλικά και ανακατεύω καλά.",
                        "translation": "I combine the wet with the dry ingredients and mix well."
                    },
                    {
                        "sentence": "Βάζω τη ζύμη στο ταψί και τη βάζω στον φούρνο.",
                        "translation": "I put the batter in the pan and put it in the oven."
                    },
                    {
                        "sentence": "Μετά από μισή ώρα, το κέικ είναι έτοιμο!",
                        "translation": "After half an hour, the cake is ready!"
                    },
                    {
                        "sentence": "Το πασπαλίζω με ζάχαρη άχνη και λίγη κανέλα.",
                        "translation": "I sprinkle it with powdered sugar and a little cinnamon."
                    }
                ]
            }
