            "story": {
                "sentences": [
                    {
                        "sentence": "Ο Γιώργης δεν αισθάνεται καλά σήμερα.",
                        "translation": "Giorgis doesn't feel well today."
                    },
                    {
                        "sentence": "Έχει υψηλό πυρετό και δυνατό βήχα.",
                        "translation": "He has a high fever and a strong cough."
                    },
                    {
                        "sentence": "Τηλεφωνεί στο ιατρείο και κλείνει ένα ραντεβού.",
                        "translation": "He calls the clinic and makes an appointment."
                    },
                    {
                        "sentence": "Ο γιατρός τον εξετάζει με προσοχή.",
                        "translation": "The doctor examines him carefully."
                    },
                    {
                        "sentence": "«Έχεις βαρύ κρυολόγημα», λέει ο γιατρός.",
                        "translation": "'You have a heavy cold,' says the doctor."
                    },
                    {
                        "sentence": "Ο γιατρός του γράφει μια συνταγή.",
                        "translation": "The doctor writes him a prescription."
                    },
                    {
                        "sentence": "Ο Γιώργης πηγαίνει στο φαρμακείο και παίρνει το φάρμακο.",
                        "translation": "Giorgis goes to the pharmacy and picks up the medicine."
                    },
                    {
                        "sentence": "Ο πόνος στο κεφάλι του σιγά σιγά φεύγει.",
                        "translation": "The pain in his head slowly goes away."
                    },
                    {
                        "sentence": "Μετά από τρεις μέρες, αισθάνεται πολύ καλύτερα.",
                        "translation": "After three days, he feels much better."
                    }
                ]
            }
